{

  "name"                        : "@langpkg/cli",
  "version"                     : "0.0.2",
  "description"                 : "Zero-dependency CLI framework for fast, organized, and validated command-line applications.",
  "keywords"                    : ["langpkg", "cli"],
  "license"                     : "MIT",
  "author"                      : {
    "email"                     : "maysara.elshewehy@gmail.com",
    "name"                      : "Maysara",
    "url"                       : "https://github.com/maysara-elshewehy"
  },
  "type"                        : "module",

  "homepage"                    : "https://github.com/langpkg/cli#readme",
  "bugs"                        : {
    "url"                       : "https://github.com/langpkg/cli/issues"
  },
  "repository"                  : {
    "type"                      : "git",
    "url"                       : "git+https://github.com/langpkg/cli.git"
  },

  "main"                        : "./dist/index.cjs",
  "types"                       : "./dist/index.d.ts",
  "files"                       : ["dist"],
  "exports"                     : {
    "."                         : {
      "import"                  : "./dist/index.js",
      "require"                 : "./dist/index.cjs",
      "types"                   : "./dist/index.d.ts"
    }
  },
  "engines"                     : {
    "bun"                       : ">=1.3.3"
  },
  "module"                      : "./dist/index.js",

  "pkg"                         : {
    "type"                      : "pkg"
  },

  "scripts"                     : {
    "build"                     : "tsup",
    "lint"                      : "eslint src --ext .ts",
    "test"                      : "bun test"
  },

  "peerDependencies"            : {
    "bun"                       : "^1.3.14"
  },
  "devDependencies"             : {
    "@eslint/js"                : "^10.0.1",
    "@stylistic/eslint-plugin"  : "^5.10.0",
    "@types/bun"                : "^1.3.14",
    "@types/node"               : "^25.9.1",
    "bun-plugin-dts"            : "^0.4.0",
    "bun-types"                 : "^1.3.14",
    "ts-node"                   : "^10.9.2",
    "tsup"                      : "^8.5.1",
    "typescript"                : "^6.0.3",
    "typescript-eslint"         : "^8.59.4"
  }

}
